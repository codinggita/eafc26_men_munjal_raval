# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas (use this for Render deployment) ───────────────────────────
# Local:  mongodb://localhost:27017/war_economic_impact
# Atlas:  mongodb+srv://<username>:<password>@cluster.mongodb.net/war_economic_impact
MONGO_URI=mongodb://localhost:27017/war_economic_impact

# ─── JWT Secrets (change these in production!) ────────────────────────────────
JWT_SECRET=war_impact_jwt_secret_2026_change_in_production
JWT_REFRESH_SECRET=war_impact_refresh_secret_2026_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ─── Admin Registration Key ────────────────────────────────────────────────────
ADMIN_SECRET_KEY=admin_register_key_2026
